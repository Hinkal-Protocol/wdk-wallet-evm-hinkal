# Example configuration for examples/private-transfer.js and the integration
# tests (npm run test:integration). Copy to .env and fill in.
# Never commit real secrets. The integration tests skip themselves when SEED,
# RPC_URL, or TOKEN are unset.

# BIP-39 mnemonic of a FUNDED wallet (needs the token + gas). Fill in.
SEED=""

# EVM RPC endpoint.
RPC_URL="https://mainnet.optimism.io"

# ERC-20 token address supported by Hinkal on that chain (USDC on Optimism shown).
TOKEN="0x0b2C639c533813f4Aa9D7837CAf62653d097Ff85"

# Destination for the private send (defaults to the wallet's own address).
RECIPIENT=""

# Amount in the token's base units (10000 = 0.01 USDC, 6 decimals).
AMOUNT="10000"
