# Configuration for examples/private-transfer.js and the integration tests
# (npm run test:integration). Copy to .env and fill in. Never commit real
# secrets. The integration tests skip themselves when any var below is unset.

# BIP-39 mnemonic of a FUNDED wallet (needs the token + gas).
SEED=""

# EVM RPC endpoint (Arc Testnet shown).
RPC_URL="https://arc-testnet.g.alchemy.com/v2/<your-key>"

# Chain id of the network the RPC points at (Arc Testnet = 5042002).
CHAIN_ID="5042002"

# ERC-20 token address supported by Hinkal on that chain.
TOKEN=""

# Destination address for the private send.
RECIPIENT=""

# Amount in the token's base units (10000 = 0.01 for a 6-decimal token).
AMOUNT="10000"
