# Example configuration for examples/private-transfer.js.
# Copy to .env and fill in. Never commit real secrets.

# BIP-39 mnemonic of a FUNDED wallet (needs the token + gas). Fill in.
SEED=""

# EVM RPC endpoint (Ethereum Sepolia testnet shown).
RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"

# ERC-20 token address supported by Hinkal on that chain. Fill in with a
# Hinkal-supported token for your network.
TOKEN=""

# Destination for the private send (defaults to the wallet's own address).
RECIPIENT=""

# Amount in the token's base units (10000 = 0.01 for a 6-decimal token).
AMOUNT="10000"
